<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Progress - Diet Dash</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
  <a class="navbar-brand" href="/"><i class="fas fa-leaf"></i> Diet Dash</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/user/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>
          <li class="nav-item"><a class="nav-link active" href="/user/progress">Progress</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <h2 class="mb-4">Your Progress</h2>

    <div class="row g-3 mb-4">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header"><strong>Calories Trend (Last 30 days)</strong></div>
          <div class="card-body">
            <canvas id="calChart" height="140"></canvas>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-header"><strong>Streaks</strong></div>
          <div class="card-body">
            <div class="row text-center">
              <div class="col">
                <div class="stat-number"><%= currentStreak %></div>
                <div class="stat-label">Current Streak</div>
              </div>
              <div class="col">
                <div class="stat-number"><%= bestStreak %></div>
                <div class="stat-label">Best Streak</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><strong>Diet Logs</strong></div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>Date</th>
                <th>Calories</th>
                <th>Protein</th>
                <th>Carbs</th>
                <th>Fats</th>
              </tr>
            </thead>
            <tbody>
              <% if ((dietLogs || []).length === 0) { %>
                <tr><td colspan="5" class="text-center text-muted py-3">No logs yet.</td></tr>
              <% } %>
              <% (dietLogs || []).forEach(l => { %>
                <tr>
                  <td><%= new Date(l.date).toLocaleDateString() %></td>
                  <td><%= l.totalNutrition?.calories || 0 %></td>
                  <td><%= l.totalNutrition?.protein || 0 %> g</td>
                  <td><%= l.totalNutrition?.carbs || 0 %> g</td>
                  <td><%= l.totalNutrition?.fats || 0 %> g</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <script>
    (function(){
      const ctx = document.getElementById('calChart').getContext('2d');
      const payloadB64 = '<%= chartPayloadB64 %>';
      let labels = [], data = [];
      try {
        const parsed = JSON.parse(Buffer ? Buffer.from(payloadB64, 'base64').toString('utf8') : atob(payloadB64));
        labels = parsed.labels || [];
        data = parsed.data || [];
      } catch (e) {
        try {
          const decoded = atob(payloadB64);
          const parsed = JSON.parse(decoded);
          labels = parsed.labels || [];
          data = parsed.data || [];
        } catch (e2) {
          labels = [];
          data = [];
        }
      }

      new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{ label: 'Calories', data: data, borderColor: '#667eea', backgroundColor: 'rgba(102,126,234,0.2)' }]
        },
        options: { responsive: true, plugins: { legend: { display: true } } }
      });
    })();
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>