<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Watchlist - Diet Dash</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
  <a class="navbar-brand" href="/"><i class="fas fa-leaf"></i> Diet Dash</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/user/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link active" href="/user/watchlist">Watchlist</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/cart">Cart <span class="badge bg-secondary cart-badge"><%= (user.cart && user.cart.length) || 0 %></span></a></li>
          <li class="nav-item ms-3 d-flex align-items-center theme-toggle">
            <input type="checkbox" id="themeSwitchLocal" class="theme-toggle-checkbox" />
            <label for="themeSwitchLocal" class="theme-switch-label">
              <i class="bi bi-brightness-high-fill icon-light"></i>
              <i class="bi bi-moon-fill icon-dark"></i>
            </label>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Your Watchlist</h2>
      <a href="/user/dashboard" class="btn btn-outline-secondary">Back to Menu</a>
    </div>

    <div class="row g-3">
      <% if (!items || items.length === 0) { %>
        <div class="col-12 text-center text-muted py-5">Your watchlist is empty.</div>
      <% } %>

      <% (items || []).forEach(f => { %>
        <div class="col-md-4">
          <div class="card">
            <% if (f.image) { %>
              <img src="<%= f.image %>" class="card-img-top" style="height:180px;object-fit:cover;" />
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= f.name %></h5>
              <p class="text-muted small"><%= f.nutrition?.calories || 0 %> kcal • ₹<%= f.price %></p>
                <div class="d-flex gap-2">
                <a href="#" class="btn btn-sm btn-success add-to-cart-btn" data-id="<%= f._id %>">Add to Cart</a>
                <button class="btn btn-sm btn-outline-danger remove-watchlist" data-id="<%= f._id %>">Remove</button>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </main>

<script>
  function placeOrder(id){
    alert('Place order UI is not implemented in watchlist. Use the main order flow.');
  }

  document.querySelectorAll('.remove-watchlist').forEach(btn => btn.addEventListener('click', async function(){
    const id = this.dataset.id;
    try{
      const res = await fetch('/user/watchlist/remove', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type':'application/json' }, body: JSON.stringify({ foodId: id }) });
      const j = await res.json();
      if (j.success) location.reload(); else alert('Could not remove');
    } catch(e){ alert('Network'); }
  }));

  document.querySelectorAll('.add-to-cart-btn').forEach(btn => btn.addEventListener('click', async function(e){
    e.preventDefault();
    const id = this.dataset.id;
    try{
      const res = await fetch('/user/cart/add', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type':'application/json' }, body: JSON.stringify({ foodId: id, quantity: 1 }) });
      const j = await res.json();
      if (j.success) {
        // redirect to cart page
        window.location.href = '/user/cart';
      } else {
        alert(j.message || 'Could not add to cart');
      }
    } catch(err){ alert('Network error'); }
  }));
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/cart.js"></script>
<script src="/js/theme.js"></script>
</body>
</html>
