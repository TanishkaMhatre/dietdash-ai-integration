<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your Cart - Diet Dash</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-warning">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="fas fa-leaf"></i> Diet Dash</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavCart">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNavCart">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/user/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/watchlist">Watchlist</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>
          <li class="nav-item"><a class="nav-link active" href="/user/cart">Cart <span class="badge bg-secondary cart-badge"><%= (user.cart && user.cart.length) || 0 %></span></a></li>
          <li class="nav-item ms-3 d-flex align-items-center theme-toggle">
            <input type="checkbox" id="themeSwitchLocal" class="theme-toggle-checkbox" />
            <label for="themeSwitchLocal" class="theme-switch-label">
              <i class="bi bi-brightness-high-fill icon-light"></i>
              <i class="bi bi-moon-fill icon-dark"></i>
            </label>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Your Cart</h2>
      <a href="/user/dashboard" class="btn btn-outline-secondary">Back to Menu</a>
    </div>

    <% if (!items || items.length === 0) { %>
      <div class="text-center text-muted py-5">Your cart is empty.</div>
    <% } else { %>
      <div class="row">
        <div class="col-md-8">
          <% let subtotal = 0; %>
          <% items.forEach(it => { %>
            <% const f = it.foodItem; const qty = it.quantity || 1; const line = (f && f.price?f.price:0) * qty; subtotal += line; %>
            <div class="card mb-3">
              <div class="row g-0">
                <div class="col-4">
                  <% if (f && f.image && f.image.filename) { %>
                    <img src="/uploads/<%= f.image.filename %>" class="img-fluid" style="height:120px;object-fit:cover;" />
                  <% } else if (f && f.imageUrl) { %>
                    <img src="<%= f.imageUrl %>" class="img-fluid" style="height:120px;object-fit:cover;" />
                  <% } %>
                </div>
                <div class="col-8">
                  <div class="card-body">
                    <h5 class="card-title"><%= f ? f.name : 'Item' %></h5>
                    <p class="text-muted small"><%= f ? (f.nutrition?.calories||0) + ' kcal' : '' %></p>
                    <div class="d-flex gap-2 align-items-center">
                      <small>Qty: <strong><%= qty %></strong></small>
                      <button class="btn btn-sm btn-outline-danger ms-auto remove-item" data-id="<%= f?f._id:'' %>">Remove</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
        <div class="col-md-4">
          <div class="card p-3">
            <h5>Order Summary</h5>
            <p>Subtotal: ₹<%= subtotal %></p>
            <p>Delivery: ₹<%= subtotal > 500 ? 0 : 40 %></p>
            <p>Tax (5%): ₹<%= Math.round(subtotal * 0.05) %></p>
            <hr />
            <h4>Total: ₹<%= subtotal + (subtotal > 500 ? 0 : 40) + Math.round(subtotal * 0.05) %></h4>
            <form id="addressForm" class="mb-3">
              <h6 class="mb-2">Delivery Address</h6>
              <input type="text" class="form-control mb-2" name="street" placeholder="Street" value="<%= user.profile?.address?.street || '' %>" required>
              <input type="text" class="form-control mb-2" name="city" placeholder="City" value="<%= user.profile?.address?.city || '' %>" required>
              <input type="text" class="form-control mb-2" name="state" placeholder="State" value="<%= user.profile?.address?.state || '' %>" required>
              <input type="text" class="form-control mb-2" name="zip" placeholder="Zip Code" value="<%= user.profile?.address?.zip || '' %>" required>
            </form>
            <button id="placeOrder" class="btn btn-success w-100 mt-3" disabled>Place Order</button>
          </div>
        </div>
      </div>
    <% } %>
  </main>

<script>
  document.querySelectorAll('.remove-item').forEach(btn => btn.addEventListener('click', async function(e){
    const id = this.dataset.id;
    try{
      const res = await fetch('/user/cart/remove', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type':'application/json' }, body: JSON.stringify({ foodId: id }) });
      const j = await res.json();
      if (j.success) location.reload(); else alert('Could not remove');
    } catch(err){ alert('Network'); }
  }));

  const addressForm = document.getElementById('addressForm');
  const placeOrderBtn = document.getElementById('placeOrder');
  function validateAddress() {
    if (!addressForm) return false;
    return Array.from(addressForm.elements).every(input => !input.required || input.value.trim().length > 0);
  }
  addressForm?.addEventListener('input', function() {
    placeOrderBtn.disabled = !validateAddress();
  });
  placeOrderBtn?.addEventListener('click', async function(){
    if (!validateAddress()) {
      alert('Please fill all address fields.');
      return;
    }
    const data = {};
    Array.from(addressForm.elements).forEach(input => { if (input.name) data[input.name] = input.value.trim(); });
    try{
      const res = await fetch('/user/cart/place', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type':'application/json' }, body: JSON.stringify({ address: data }) });
      const j = await res.json();
      if (j.success) {
        const info = j.totalNutrition || {};
        const msg = `Order placed ✓\nOrder ID: ${j.orderId}\nCalories: ${info.calories||0} kcal\nProtein: ${info.protein||0} g\nCarbs: ${info.carbs||0} g\nFats: ${info.fats||0} g`;
        alert(msg);
        setTimeout(() => { location.href = '/user/dashboard'; }, 200);
      } else {
        alert('Could not place order: ' + (j.message || ''));
      }
    } catch(err){ console.error(err); alert('Network'); }
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/cart.js"></script>
<script src="/js/theme.js"></script>
</body>
</html>