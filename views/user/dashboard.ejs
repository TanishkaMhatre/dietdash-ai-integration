<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Dashboard - Diet Dash</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="fas fa-leaf"></i> Diet Dash</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link active" href="/user/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/profile">Profile</a></li>
          <li class="nav-item"><a class="nav-link" href="/user/cart">Cart <span class="badge bg-secondary cart-badge"><%= (user.cart && user.cart.length) || 0 %></span></a></li>
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item ms-3 d-flex align-items-center theme-toggle">
            <input type="checkbox" id="themeSwitchLocal" class="theme-toggle-checkbox" />
            <label for="themeSwitchLocal" class="theme-switch-label">
              <i class="bi bi-brightness-high-fill icon-light"></i>
              <i class="bi bi-moon-fill icon-dark"></i>
            </label>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Hello, <%= user?.username %></h2>
      <form action="/auth/logout" method="POST">
        <button class="btn btn-outline-danger btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</button>
      </form>
    </div>

    <div class="row g-3">
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= progress.calories.consumed %>/<%= progress.calories.target %></div>
          <div class="stat-label">Calories (kcal)</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= progress.protein.consumed %>/<%= progress.protein.target %></div>
          <div class="stat-label">Protein (g)</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= progress.carbs.consumed %>/<%= progress.carbs.target %></div>
          <div class="stat-label">Carbs (g)</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= progress.fats.consumed %>/<%= progress.fats.target %></div>
          <div class="stat-label">Fats (g)</div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-lg-6 mb-4">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Today's Meal Plan</strong>

            <% if (aiMeta) { %>
              <span class="badge bg-success">
                AI Engine ✅ | <%= aiMeta.goal %> | <%= aiMeta.diet %> | Daily: <%= aiMeta.daily_calories %> kcal
              </span>
            <% } else { %>
              <span class="badge bg-secondary">DB Fallback</span>
            <% } %>
          </div>

          <div class="card-body">
            <div class="row g-3">
              <% const mealTypes=['breakfast','lunch','dinner','snacks']; %>
              <% mealTypes.forEach(type => { %>
                <div class="col-12">
                  <h6 class="text-uppercase text-muted mb-2"><%= type %></h6>
                  <div class="d-flex flex-wrap gap-2">
                    <% (recommendedFoods || []).filter(f => f.category===type).forEach(f => { %>
                      <div class="border p-2 rounded d-flex align-items-center" style="min-width:180px;">
                        <div style="width:64px;height:64px;flex:0 0 64px;margin-right:10px;">
                          <% if (f.imageUrl) { %>
                            <img src="<%= f.imageUrl %>" style="width:64px;height:64px;object-fit:cover;border-radius:6px;" />
                          <% } else if (f.image && f.image.filename) { %>
                            <img src="/uploads/<%= f.image.filename %>" style="width:64px;height:64px;object-fit:cover;border-radius:6px;" />
                          <% } else { %>
                            <div style="width:64px;height:64px;background:#f0f0f0;border-radius:6px;"></div>
                          <% } %>
                        </div>

                        <div style="flex:1 1 auto;">
                          <div class="fw-bold">
                            <%= f.name %>
                            <% if (f.isAi) { %>
                              <span class="badge bg-warning text-dark ms-1">AI</span>
                            <% } %>
                          </div>

                          <small class="text-muted">
                            <%= f.nutrition.calories %> kcal | P <%= f.nutrition.protein %>g
                          </small>

                          <div>
                            <% if (f._id) { %>
                              <a class="btn btn-sm btn-outline-primary mt-1 add-to-cart-btn" data-id="<%= f._id %>">Add</a>
                            <% } else { %>
                              <span class="text-muted" style="font-size:12px;">Suggestion (not orderable)</span>
                            <% } %>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6 mb-4">
        <div class="card h-100">
          <div class="card-header"><strong>Recent Orders</strong></div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead><tr><th>#</th><th>Items</th><th>Total</th><th>Date</th></tr></thead>
                <tbody>
                  <% if ((recentOrders || []).length === 0) { %>
                    <tr><td colspan="4" class="text-center text-muted py-3">No orders yet.</td></tr>
                  <% } %>
                  <% (recentOrders || []).forEach(o => { %>
                    <tr>
                      <td><%= o.orderNumber %></td>
                      <td><%= (o.items||[]).map(i => i.foodItem?.name).filter(Boolean).join(', ') %></td>
                      <td>₹<%= o.finalAmount %></td>
                      <td><%= new Date(o.createdAt).toLocaleString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    gsap.from('.stat-card', { y: 20, opacity: 0, duration: 0.6, stagger: 0.15, ease: 'power2.out' });
    gsap.from('.card', { y: 30, opacity: 0, duration: 0.6, stagger: 0.1, delay: 0.2, ease: 'power2.out' });
  </script>
  <script src="/js/cart.js"></script>
  <script src="/js/theme.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>