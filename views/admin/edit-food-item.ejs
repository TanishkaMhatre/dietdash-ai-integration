<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Food Item - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
  <a class="navbar-brand" href="/admin/dashboard"><i class="fas fa-leaf"></i> Diet Dash Admin</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/food-items">Food Items</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/orders">Orders</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Edit Food Item</h2>
      <a class="btn btn-outline-secondary" href="/admin/food-items">Back</a>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/admin/food-items/edit/<%= foodItem._id %>" method="POST" enctype="multipart/form-data" class="row g-3">
      <div class="col-md-6">
        <label class="form-label">Name</label>
        <input class="form-control" name="name" value="<%= formData.name %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">Price (₹)</label>
        <input type="number" class="form-control" step="0.01" name="price" value="<%= formData.price %>" required>
      </div>
      <div class="col-md-3">
        <label class="form-label">Replace Image</label>
        <input type="file" class="form-control" name="image" accept="image/*">
      </div>

      <div class="col-12">
        <label class="form-label">Description</label>
        <textarea class="form-control" name="description" rows="2"><%= formData.description %></textarea>
      </div>

      <div class="col-md-4">
        <label class="form-label">Category</label>
        <select class="form-select" name="category" required>
          <%- ['breakfast','lunch','dinner','snacks','drinks','desserts'].map(c => `<option ${formData.category===c?'selected':''} value="${c}">${c}</option>`).join('') %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Cuisine Type</label>
        <select class="form-select" name="cuisineType" required>
          <%- ['indian','italian','chinese','mexican','american','thai','continental','japanese','korean','mediterranean'].map(c => `<option ${formData.cuisineType===c?'selected':''} value="${c}">${c}</option>`).join('') %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">Spice Level</label>
        <select class="form-select" name="spiceLevel">
          <%- ['mild','medium','spicy','extra_spicy'].map(c => `<option ${formData.spiceLevel===c?'selected':''} value="${c}">${c}</option>`).join('') %>
        </select>
      </div>

      <div class="col-12"><h5 class="mt-3">Nutrition (per serving)</h5></div>
      <div class="col-md-2">
        <label class="form-label">Calories</label>
        <input type="number" class="form-control" name="calories" value="<%= formData.calories %>" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Protein (g)</label>
        <input type="number" class="form-control" name="protein" value="<%= formData.protein %>" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Carbs (g)</label>
        <input type="number" class="form-control" name="carbs" value="<%= formData.carbs %>" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Fats (g)</label>
        <input type="number" class="form-control" name="fats" value="<%= formData.fats %>" required>
      </div>
      <div class="col-md-2">
        <label class="form-label">Fiber (g)</label>
        <input type="number" class="form-control" name="fiber" value="<%= formData.fiber %>">
      </div>
      <div class="col-md-2">
        <label class="form-label">Sugar (g)</label>
        <input type="number" class="form-control" name="sugar" value="<%= formData.sugar %>">
      </div>

      <div class="col-12"><h5 class="mt-3">Restaurant</h5></div>
      <div class="col-md-4">
        <label class="form-label">Name</label>
        <input class="form-control" name="restaurantName" value="<%= formData.restaurantName %>" required>
      </div>
      <div class="col-md-4">
        <label class="form-label">Address</label>
        <input class="form-control" name="restaurantAddress" value="<%= formData.restaurantAddress %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Phone</label>
        <input class="form-control" name="restaurantPhone" value="<%= formData.restaurantPhone %>">
      </div>

      <div class="col-md-4">
        <label class="form-label">Preparation Time</label>
        <input class="form-control" name="preparationTime" value="<%= formData.preparationTime %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Serving Size</label>
        <input class="form-control" name="servingSize" value="<%= formData.servingSize %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Dietary Tags</label>
        <select class="form-select" name="dietaryTags" multiple>
          <%- ['vegetarian','vegan','jain','gluten_free','keto','diabetic_friendly','low_sodium','high_protein','low_carb','dairy_free'].map(t => `<option ${Array.isArray(formData.dietaryTags) && formData.dietaryTags.includes(t)?'selected':''} value="${t}">${t}</option>`).join('') %>
        </select>
      </div>

      <div class="col-12">
        <label class="form-label">Ingredients (JSON array)</label>
        <textarea class="form-control" name="ingredients" rows="3"><%= Array.isArray(foodItem.ingredients)? JSON.stringify(foodItem.ingredients) : (formData.ingredients || '') %></textarea>
      </div>

      <div class="col-12">
        <button class="btn btn-primary">Update Item</button>
      </div>
    </form>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>