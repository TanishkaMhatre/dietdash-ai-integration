<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Orders - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
  <a class="navbar-brand" href="/admin/dashboard"><i class="fas fa-leaf"></i> Diet Dash Admin</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/food-items">Food Items</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/orders">Orders</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Orders</h2>
      <form class="d-flex" method="GET">
        <select class="form-select me-2" name="status">
          <option value="">All Statuses</option>
          <%- ['pending','confirmed','preparing','out_for_delivery','delivered','cancelled'].map(s => `<option ${status===s?'selected':''} value="${s}">${s}</option>`).join('') %>
        </select>
        <button class="btn btn-outline-primary">Filter</button>
      </form>
    </div>

    <div class="card">
      <div class="table-responsive">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th>Order #</th>
              <th>User</th>
              <th>Items</th>
              <th>Total</th>
              <th>Status</th>
              <th>Placed</th>
            </tr>
          </thead>
          <tbody>
            <% if ((orders || []).length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-3">No orders found.</td></tr>
            <% } %>
            <% (orders || []).forEach(o => { %>
              <tr>
                <td><%= o.orderNumber %></td>
                <td><%= o.userId?.username || 'User' %></td>
                <td><%= (o.items||[]).map(i => i.foodItem?.name).filter(Boolean).join(', ') %></td>
                <td>₹<%= o.finalAmount %></td>
                <td><span class="badge bg-secondary text-uppercase"><%= o.status %></span></td>
                <td><%= new Date(o.createdAt).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let p=1; p<= (totalPages||1); p++) { %>
          <li class="page-item <%= p=== (currentPage||1)?'active':'' %>">
            <a class="page-link" href="?page=<%= p %>&status=<%= status||'' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>