<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
  <a class="navbar-brand" href="/admin/dashboard"><i class="fas fa-leaf"></i> Diet Dash Admin</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/food-items">Food Items</a></li>
          <li class="nav-item"><a class="nav-link active" href="/admin/users">Users</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/orders">Orders</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2>Users</h2>
      <form class="d-flex" method="GET">
        <input class="form-control me-2" name="search" placeholder="Search username or email" value="<%= search || '' %>">
        <button class="btn btn-outline-primary">Search</button>
      </form>
    </div>

    <div class="card">
      <div class="table-responsive">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
              <th>Role</th>
              <th>Profile</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% if ((users || []).length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted py-3">No users found.</td></tr>
            <% } %>
            <% (users || []).forEach(u => { %>
              <tr>
                <td><%= u.username %></td>
                <td><%= u.email %></td>
                <td class="text-uppercase"><%= u.role %></td>
                <td>
                  <% if (u.profile && u.profile.height) { %>
                    <small>
                      H: <%= u.profile.height %> cm, W: <%= u.profile.weight %> kg,
                      Goal: <%= u.profile.healthGoal || '-' %>
                    </small>
                  <% } else { %>
                    <small class="text-muted">Not completed</small>
                  <% } %>
                </td>
                <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <nav class="mt-4">
      <ul class="pagination justify-content-center">
        <% for (let p=1; p<= (totalPages||1); p++) { %>
          <li class="page-item <%= p=== (currentPage||1)?'active':'' %>">
            <a class="page-link" href="?page=<%= p %>&search=<%= search||'' %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>