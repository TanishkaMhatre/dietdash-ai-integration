<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Diet Dash</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/admin/dashboard"><i class="fas fa-leaf"></i> Diet Dash Admin</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link active" href="/admin/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/food-items">Food Items</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/users">Users</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/orders">Orders</a></li>
          <li class="nav-item"><a class="nav-link" href="/">Site</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Welcome, <%= user?.username || 'Admin' %></h2>
      <form action="/auth/logout" method="POST">
        <button class="btn btn-outline-danger btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</button>
      </form>
    </div>

    <div class="row g-3">
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= stats?.totalUsers || 0 %></div>
          <div class="stat-label">Total Users</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= stats?.totalFoodItems || 0 %></div>
          <div class="stat-label">Food Items</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number"><%= stats?.totalOrders || 0 %></div>
          <div class="stat-label">Total Orders</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-card">
          <div class="stat-number">₹<%= (stats?.totalRevenue || 0).toLocaleString('en-IN') %></div>
          <div class="stat-label">Delivered Revenue</div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-lg-6 mb-4">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <strong><i class="fas fa-receipt"></i> Recent Orders</strong>
            <a class="btn btn-sm btn-outline-primary" href="/admin/orders">View all</a>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th>Order #</th>
                    <th>User</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                  </tr>
                </thead>
                <tbody>
                  <% if ((recentOrders || []).length === 0) { %>
                    <tr><td colspan="5" class="text-center text-muted py-3">No orders yet.</td></tr>
                  <% } %>
                  <% (recentOrders || []).forEach(o => { %>
                    <tr>
                      <td><%= o.orderNumber %></td>
                      <td><%= o.userId?.username || 'User' %></td>
                      <td>₹<%= o.finalAmount %></td>
                      <td><span class="badge bg-secondary text-uppercase"><%= o.status %></span></td>
                      <td><%= new Date(o.createdAt).toLocaleString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-6 mb-4">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <strong><i class="fas fa-star"></i> Popular Food Items</strong>
            <a class="btn btn-sm btn-outline-primary" href="/admin/food-items">Manage</a>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table mb-0">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Orders</th>
                    <th>Qty</th>
                    <th>Rating</th>
                  </tr>
                </thead>
                <tbody>
                  <% if ((popularFoodItems || []).length === 0) { %>
                    <tr><td colspan="4" class="text-center text-muted py-3">No data yet.</td></tr>
                  <% } %>
                  <% (popularFoodItems || []).forEach(p => { %>
                    <tr>
                      <td><%= p.foodItem?.name %></td>
                      <td><%= p.orderCount %></td>
                      <td><%= p.totalQuantity %></td>
                      <td><%= p.foodItem?.averageRating || 0 %> ⭐</td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card mt-2">
      <div class="card-header"><strong><i class="fas fa-users"></i> New Users</strong></div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead>
              <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Joined</th>
              </tr>
            </thead>
            <tbody>
              <% if ((recentUsers || []).length === 0) { %>
                <tr><td colspan="3" class="text-center text-muted py-3">No users yet.</td></tr>
              <% } %>
              <% (recentUsers || []).forEach(u => { %>
                <tr>
                  <td><%= u.username %></td>
                  <td><%= u.email %></td>
                  <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
</main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    gsap.from('.stat-card', { y: 20, opacity: 0, duration: 0.6, stagger: 0.15, ease: 'power2.out' });
    gsap.from('.card', { y: 30, opacity: 0, duration: 0.6, stagger: 0.1, delay: 0.2, ease: 'power2.out' });
  </script>
</body>
</html>